# ============================================================
# .env — Environment variables for Docker Compose
# Copy this file to .env and fill in real values.
# NEVER commit .env with real credentials to version control.
# ============================================================

# PostgreSQL

DB_HOST=postgres
DB_PORT=5432
DB_NAME=orderpayment
DB_USERNAME=postgres
DB_PASSWORD=123456789

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Security

SECURITY_ADMIN_USER=admin
SECURITY_ADMIN_PASSWORD=admin123
SECURITY_USER_USER=user
SECURITY_USER_PASSWORD=user123

# --- Docker Image ---
DOCKER_REGISTRY=order-payment-system
IMAGE_TAG=latest
